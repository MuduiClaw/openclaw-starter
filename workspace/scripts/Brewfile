# OpenClaw Starter Kit — Minimal Brewfile
# Core dependencies for OpenClaw workspace

brew "gh"               # GitHub CLI
brew "ripgrep"          # Fast code search
brew "shellcheck"       # Shell script linter
brew "ffmpeg"           # Media processing (video-frames skill)
brew "imagemagick"      # Image manipulation
brew "pandoc"           # Document conversion
brew "tmux"             # Terminal multiplexer (tmux skill)
brew "wget"             # HTTP fetcher

