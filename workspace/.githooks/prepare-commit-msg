#!/usr/bin/env bash
# PREPARE-COMMIT-MSG: Global pre-commit gate (shared across all projects)
# Install: git config [--global] core.hooksPath <workspace>/.githooks/
# Project-specific gates: .githooks/project-gates.sh (sourced after global gates)
set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# вФАвФАвФА Portable path discovery вФАвФАвФА
# Hooks live in <workspace>/.githooks/ вАФ derive workspace root from hook location
HOOKS_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE_ROOT="$(dirname "$HOOKS_DIR")"

# Telemetry helper (fire and forget, never block on telemetry failures)
TELEMETRY="${WORKSPACE_ROOT}/scripts/gate-telemetry.sh"
_tel() { [[ -x "$TELEMETRY" ]] && "$TELEMETRY" "$@" 2>/dev/null || true; }

# Skip for merge/squash
case "$COMMIT_SOURCE" in
  merge|squash) exit 0 ;;
esac

# Workspace repos (SOUL.md present) = relaxed mode: warn on syntax, don't block
repo_root="$(git rev-parse --show-toplevel)"
WORKSPACE_MODE=0
if [[ -f "$repo_root/SOUL.md" || -f "$repo_root/HEARTBEAT.md" ]]; then
  WORKSPACE_MODE=1
fi

# Strip any user-injected Pre-commit-gate trailer (anti-forgery: only this hook writes it)
# For amends (COMMIT_SOURCE=commit), strip and regenerate since tree may have changed
if grep -q '^Pre-commit-gate: ' "$COMMIT_MSG_FILE" 2>/dev/null; then
  sed -i '' '/^Pre-commit-gate: /d' "$COMMIT_MSG_FILE"
fi

# Read commit message (first line)
commit_msg_line=""
if [[ -f "$COMMIT_MSG_FILE" ]]; then
  commit_msg_line="$(head -1 "$COMMIT_MSG_FILE")"
fi

# Collect ALL staged files for scope check
all_staged=()
while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  all_staged+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMRD)

staged_count=${#all_staged[@]}

# ============================================================
# Gate 0: Prompt CHANGELOG вАФ runs even for pure markdown changes
# ============================================================
prompt_changed=0
changelog_changed=0
for f in ${all_staged[@]+"${all_staged[@]}"}; do
  case "$f" in
    prompts/cron/*.prompt.md|prompts/*.prompt.md) prompt_changed=1 ;;
    prompts/CHANGELOG.md) changelog_changed=1 ;;
  esac
done

if [[ $prompt_changed -eq 1 && $changelog_changed -eq 0 ]]; then
  echo ""
  echo "вЫФ COMMIT BLOCKED вАФ жФєдЇЖ prompt дљЖж≤°жЫіжЦ∞ CHANGELOG"
  echo "  prompts/CHANGELOG.md жЬ™еЬ® staged files дЄ≠гАВ"
  echo "  ж†ЉеЉП: - [YYYY-MM-DD] <job-slug> <version> вАФ <еПШжЫіжСШи¶Б>"
  _tel hook-changelog block
  exit 1
elif [[ $prompt_changed -eq 1 && $changelog_changed -eq 1 ]]; then
  _tel hook-changelog pass
fi

# ============================================================
# Gate 0.5: Scope lock вАФ staged files > 5 requires [scope-ack]
# Prevents blind `git add -A` (defect вС° еЃМжИРеБПе•љ/иМГеЫіе§±жОІ)
# ============================================================
if [[ $staged_count -gt 5 ]]; then
  echo ""
  echo "вЪ†пЄП  SCOPE CHECK: $staged_count files staged (threshold: 5)"
  echo "  Staged files:"
  for f in ${all_staged[@]+"${all_staged[@]}"}; do
    echo "    - $f"
  done
  echo ""
  # Allow backup/journal commits (auto-generated, high file count is normal)
  case "$commit_msg_line" in
    backup:*|journal:*|spec:*)
      echo "  вП≠  Auto-commit ($commit_msg_line), scope check skipped"
      _tel hook-scope-lock pass
      ;;
    *)
      if ! echo "$commit_msg_line" | grep -q '\[scope-ack\]'; then
        echo "вЫФ COMMIT BLOCKED вАФ $staged_count files staged but no [scope-ack] in commit message"
        echo "  Review the list above. If all files are intentional, add [scope-ack] to your commit message."
        echo "  Example: feat: add feature X [scope-ack]"
        echo ""
        echo "  This gate prevents blind 'git add -A'. See SOUL.md ¬І0 defect вС°."
        _tel hook-scope-lock block
        exit 1
      else
        echo "  вЬЕ [scope-ack] found, proceeding"
        _tel hook-scope-lock pass
      fi
      ;;
  esac
fi

# ============================================================
# Gate 0.7: Spec gate вАФ feature/refactor/fix commits need approved spec
# Activates for ANY project that has a tasks/ directory
# v2: expanded file types + lowered threshold (2026-03-12, gates-hardening-v2)
# ============================================================
impl_file_count=0
for f in ${all_staged[@]+"${all_staged[@]}"}; do
  # Skip non-implementation files
  case "$f" in
    node_modules/*|*/node_modules/*) continue ;;
    __tests__/*|*/__tests__/*) continue ;;
    *.test.*|*.spec.*) continue ;;
    *.d.ts) continue ;;
    *.config.*) continue ;;
  esac
  # Count implementation files (broad matching)
  case "$f" in
    *.ts|*.tsx|*.js|*.jsx|*.py|*.sh|*.go|*.rs) impl_file_count=$((impl_file_count + 1)) ;;
  esac
done

# Enforce for projects with tasks/ dir + feat/refactor/fix commits touching >=2 implementation files
if [[ $impl_file_count -ge 2 && -d "$repo_root/tasks" ]]; then
  case "$commit_msg_line" in
    feat:*|feat\(*|refactor:*|refactor\(*|fix:*|fix\(*)
      # Check for [spec:filename] reference
      spec_ref=$(echo "$commit_msg_line" | sed -n 's/.*\[spec:\([^]]*\)\].*/\1/p')
      if [[ -z "$spec_ref" ]]; then
        echo ""
        echo "вЫФ COMMIT BLOCKED вАФ feat/refactor/fix with $impl_file_count impl files but no spec reference"
        echo "  Add [spec:filename] to commit message (filename in tasks/ without .md)"
        echo "  Example: feat: add gates dashboard [spec:gates-dashboard]"
        echo "  Spec must exist at tasks/<filename>.md with Status: approved"
        _tel hook-spec block
        exit 1
      fi
      # Verify spec file exists
      spec_file="$repo_root/tasks/${spec_ref}.md"
      if [[ ! -f "$spec_file" ]]; then
        echo ""
        echo "вЫФ COMMIT BLOCKED вАФ spec file not found: $spec_file"
        echo "  Create the spec first: cp tasks/SPEC-TEMPLATE.md $spec_file"
        exit 1
      fi
      # Verify spec is approved
      if ! grep -qi 'status.*approved\|status.*in_progress\|status.*done' "$spec_file"; then
        echo ""
        echo "вЫФ COMMIT BLOCKED вАФ spec not approved: $spec_file"
        echo "  Status must be 'approved', 'in_progress', or 'done'"
        echo "  Send spec to Mudui for review first"
        exit 1
      fi
      # Verify spec is not abandoned (check only the Status header line)
      if head -10 "$spec_file" | grep -qi 'Status.*abandoned'; then
        echo ""
        echo "вЫФ COMMIT BLOCKED вАФ spec is abandoned: $spec_file"
        exit 1
      fi
      echo "  вЬЕ Spec gate: $spec_file (status verified)"

      # вФАвФА Auto-advance spec lifecycle вФАвФА
      # 1. First commit with [spec:X] вЖТ create .task-lock/slug.started + set Status: in_progress
      lock_dir="$repo_root/.task-lock"
      mkdir -p "$lock_dir"
      if [[ ! -f "$lock_dir/${spec_ref}.started" ]]; then
        echo "started=$(date '+%Y-%m-%d %H:%M:%S')" > "$lock_dir/${spec_ref}.started"
        echo "spec=tasks/${spec_ref}.md" >> "$lock_dir/${spec_ref}.started"
        # Update spec status from approved вЖТ in_progress
        if head -10 "$spec_file" | grep -qi 'Status.*approved'; then
          sed -i '' 's/`approved`/`in_progress`/' "$spec_file"
          git add "$spec_file" "$lock_dir/${spec_ref}.started" 2>/dev/null || true
          echo "  рЯУН Spec auto-advanced: approved вЖТ in_progress"
        else
          git add "$lock_dir/${spec_ref}.started" 2>/dev/null || true
        fi
      fi

      # 2. Commit message contains "delivered" вЖТ create .task-lock/slug.delivered + set Status: delivered
      if echo "$commit_msg_line" | grep -qi 'deliver'; then
        if [[ ! -f "$lock_dir/${spec_ref}.delivered" ]]; then
          echo "delivered=$(date '+%Y-%m-%d %H:%M:%S')" > "$lock_dir/${spec_ref}.delivered"
          echo "spec=tasks/${spec_ref}.md" >> "$lock_dir/${spec_ref}.delivered"
          echo "receipt=$(git rev-parse --short HEAD 2>/dev/null || echo 'pending')" >> "$lock_dir/${spec_ref}.delivered"
          # Update spec status вЖТ delivered
          sed -i '' 's/`in_progress`/`delivered`/;s/`approved`/`delivered`/;s/`done`/`delivered`/' "$spec_file"
          git add "$spec_file" "$lock_dir/${spec_ref}.delivered" 2>/dev/null || true
          echo "  рЯУ¶ Spec auto-advanced: вЖТ delivered"

          # Auto-generate acceptance report if generate-acceptance.sh exists
          # Extract step id from spec frontmatter (e.g. "S6b") or filename fallback
          local step_id
          step_id=$(grep -m1 '^\*\*Step\|^step:' "$spec_file" 2>/dev/null | sed 's/.*[Ss]\([0-9][0-9a-z]*\).*/s\1/' | tr '[:upper:]' '[:lower:]' || echo "")
          if [[ -z "$step_id" ]]; then
            # Fallback: extract from spec title line "# SPEC: S6b вАФ"
            step_id=$(head -1 "$spec_file" | sed -n 's/.*[Ss]\([0-9][0-9a-z]*\).*/s\1/p' | tr '[:upper:]' '[:lower:]' || echo "")
          fi
          if [[ -n "$step_id" && -x "$repo_root/scripts/generate-acceptance.sh" ]]; then
            bash "$repo_root/scripts/generate-acceptance.sh" "$step_id" "$spec_file" 2>/dev/null || true
            if [[ -f "tasks/${step_id}-acceptance.md" ]]; then
              git add "tasks/${step_id}-acceptance.md" 2>/dev/null || true
              echo "  рЯУЛ Acceptance report auto-generated: ${step_id}-acceptance.md"
            fi
          fi
        fi
      fi

      _tel hook-spec pass
      ;;
  esac
fi

# Collect typed staged files for syntax checks
staged_sh=()
staged_json=()
staged_yml=()
needs_check=0

for f in ${all_staged[@]+"${all_staged[@]}"}; do
  case "$f" in
    *.sh)   staged_sh+=("$f"); needs_check=1 ;;
    *.json) staged_json+=("$f"); needs_check=1 ;;
    *.yml|*.yaml) staged_yml+=("$f"); needs_check=1 ;;
  esac
done

# ============================================================
# Gate: REVIEWED=1 for code/config changes (non-clawd projects)
# ============================================================
code_changed=0
for f in ${all_staged[@]+"${all_staged[@]}"}; do
  case "$f" in
    *.py|*.js|*.jsx|*.ts|*.tsx|*.go|*.rs|*.sh|*.json|*.yml|*.yaml) code_changed=1 ;;
  esac
done

if [[ $code_changed -eq 1 && "${REVIEWED:-}" != "1" ]]; then
  # Workspace repos use their own gates (spec system), skip REVIEWED check
  if [[ $WORKSPACE_MODE -eq 0 ]]; then
    # Auto-generated commits (backup/journal) bypass REVIEWED gate
    case "$commit_msg_line" in
      backup:*|journal:*)
        : # skip REVIEWED check for auto-commits
        ;;
      *)
        echo ""
        echo "вЫФ COMMIT BLOCKED вАФ зЉЇ REVIEWED=1"
        echo "  ж£АжµЛеИ∞дї£з†Б/йЕНзљЃеПШжЫіпЉМеЕИиЗ™жµЛ+review еЖНжПРдЇ§"
        echo "  зФ®ж≥Х: REVIEWED=1 git commit -m \"...\""
        exit 1
        ;;
    esac
  fi
fi

# ============================================================
# Project-specific gates (optional)
# ============================================================
project_gates="$repo_root/.githooks/project-gates.sh"
if [[ -f "$project_gates" ]]; then
  # Export context for project gates
  export COMMIT_MSG_FILE COMMIT_MSG_LINE="$commit_msg_line"
  export STAGED_FILES="${all_staged[*]+${all_staged[*]}}"
  export STAGED_COUNT="$staged_count"
  # shellcheck source=/dev/null
  source "$project_gates"
fi

# No checkable files вЖТ stamp with tree-hash (pure docs/markdown changes)
if [[ $needs_check -eq 0 ]]; then
  tree_hash=$(git write-tree)
  printf '\nPre-commit-gate: %s\n' "$tree_hash" >> "$COMMIT_MSG_FILE"
  exit 0
fi

cd "$repo_root"
failed=0

# Gate 1: shellcheck on staged .sh files
if [[ ${#staged_sh[@]} -gt 0 ]] && command -v shellcheck &>/dev/null; then
  echo "рЯФН Pre-commit gate: shellcheck (${#staged_sh[@]} files)..."
  shellcheck_failed=0
  for f in "${staged_sh[@]}"; do
    if [[ -f "$f" ]] && ! shellcheck -S warning "$f" 2>&1; then
      echo "   вЭМ $f"
      shellcheck_failed=1
      failed=1
    fi
  done
  if [[ $shellcheck_failed -eq 1 ]]; then
    _tel hook-shellcheck block
  else
    _tel hook-shellcheck pass
  fi
fi

# Gate 2: JSON syntax on staged .json files
json_yaml_failed=0
if [[ ${#staged_json[@]} -gt 0 ]]; then
  echo "рЯФН Pre-commit gate: JSON syntax (${#staged_json[@]} files)..."
  for f in "${staged_json[@]}"; do
    if [[ -f "$f" ]] && ! python3 -m json.tool "$f" >/dev/null 2>&1; then
      echo "   вЭМ Invalid JSON: $f"
      json_yaml_failed=1
      failed=1
    fi
  done
fi

# Gate 3: YAML syntax on staged .yml/.yaml files
if [[ ${#staged_yml[@]} -gt 0 ]]; then
  echo "рЯФН Pre-commit gate: YAML syntax (${#staged_yml[@]} files)..."
  for f in "${staged_yml[@]}"; do
    if [[ -f "$f" ]] && ! python3 -c "import yaml, sys; yaml.safe_load(open(sys.argv[1]))" "$f" 2>&1; then
      echo "   вЭМ Invalid YAML: $f"
      json_yaml_failed=1
      failed=1
    fi
  done
fi

if [[ ${#staged_json[@]} -gt 0 || ${#staged_yml[@]} -gt 0 ]]; then
  if [[ $json_yaml_failed -eq 1 ]]; then
    _tel hook-json-yaml block
  else
    _tel hook-json-yaml pass
  fi
fi

# Gate 4: (Removed вАФ Prompt CHANGELOG check is already in Gate 0 above)

if [[ $failed -eq 1 ]]; then
  echo ""
  echo "вЫФ PRE-COMMIT GATE FAILED"
  echo "  Fix the errors above before committing."
  exit 1
fi

# All passed вАФ stamp with tree-hash (v2 anti-forgery)
tree_hash=$(git write-tree)
printf '\nPre-commit-gate: %s\n' "$tree_hash" >> "$COMMIT_MSG_FILE"
echo "вЬЕ Pre-commit gate: passed (tree: ${tree_hash:0:8})"
exit 0
