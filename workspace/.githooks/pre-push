#!/usr/bin/env bash
# PRE-PUSH gate: Global pre-push checks (shared across all projects)
# Only runs lightweight checks (< 5s total). Heavy checks stay in CI.
# shellcheck disable=SC2034
set -euo pipefail

echo "🔍 Pre-push gate..."

# ─── Portable path discovery ───
HOOKS_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE_ROOT="$(dirname "$HOOKS_DIR")"

# Telemetry helper — same as prepare-commit-msg
TELEMETRY="${WORKSPACE_ROOT}/scripts/gate-telemetry.sh"
_tel() { [[ -x "$TELEMETRY" ]] && "$TELEMETRY" "$@" 2>/dev/null || true; }

# Workspace repos (docs/scripts/config) get relaxed checks: warn only, don't block.
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
WORKSPACE_MODE=0
if [[ -f "$repo_root/SOUL.md" || -f "$repo_root/HEARTBEAT.md" ]]; then
  WORKSPACE_MODE=1
fi

# Get commits being pushed
REMOTE="$1"
z40=0000000000000000000000000000000000000000
failed=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "$z40" ]]; then
    # Deleting ref, skip
    continue
  fi

  if [[ "$remote_sha" == "$z40" ]]; then
    echo "  ❌ Pushing new branch — we only push main, no feature branches"
    echo "     ref: $local_ref"
    failed=1
    continue
  fi
  range="$remote_sha..$local_sha"

  # Get files changed in this push
  changed_files=()
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    changed_files+=("$f")
  done < <(git diff --name-only "$range" 2>/dev/null || true)

  # Gate 1: Conventional commit format (fast regex check)
  # Workspace repos: warn only, don't block
  while IFS= read -r msg; do
    # Skip merge commits
    [[ "$msg" == Merge* ]] && continue
    # Check format: type[(scope)]: description
    if ! echo "$msg" | grep -qE '^(feat|fix|chore|docs|style|refactor|test|perf|ci|build|revert|init|wip|i18n|backup|journal|spec)(\([^)]+\))?(!)?:'; then
      if [[ $WORKSPACE_MODE -eq 1 ]]; then
        echo "  ⚠️  Loose commit format (workspace): $msg"
      else
        echo "  ❌ Bad commit format: $msg"
        echo "     Expected: type[(scope)]: description"
        _tel hook-commit-format block
        failed=1
      fi
    fi
  done < <(git log --format='%s' "$range" 2>/dev/null || true)

  # Gate 2: Cumulative impl file check (anti-salami-slicing)
  # Skip for workspace repos — mostly scripts/config, not product code
  # Exception: .githooks/ changes always enforce (even in workspace mode)
  hooks_changed=0
  for f in "${changed_files[@]+${changed_files[@]}}"; do
    case "$f" in .githooks/*) hooks_changed=1; break ;; esac
  done
  if [[ $WORKSPACE_MODE -eq 0 ]] || [[ $hooks_changed -eq 1 ]]; then
  impl_count=$(git diff --name-only "$range" 2>/dev/null | grep -E '\.(sh|ts|tsx|js|jsx|py|go|rs)$' | sort -u | wc -l || true)
  impl_count=$(echo "$impl_count" | tr -d ' ')  # trim whitespace from wc

  repo_root="$(git rev-parse --show-toplevel)"
  if [[ "$impl_count" -ge 8 && -d "$repo_root/tasks" ]]; then
    has_spec=0
    if git log --format='%B' "$range" 2>/dev/null | grep -qE '\[spec:[^]]*\]'; then
      has_spec=1
    fi
    if [[ $has_spec -eq 0 ]]; then
      echo "  ⛔ [Gate 2] 累积 ${impl_count} 个 impl 文件但无 spec 引用"
      echo "     在任一 commit message 中加 [spec:slug] 引用 tasks/slug.md"
      echo "     Spec 是前置规划，不是事后文档——先写 spec 再动手"
      _tel hook-pre-push block
      failed=1
    else
      # Gate 2.1: Check spec file exists and is not abandoned
      spec_slug=$(git log --format='%B' "$range" 2>/dev/null | grep -oE '\[spec:([^]]*)\]' | head -1 | sed 's/\[spec://;s/\]//')
      if [[ -n "$spec_slug" ]]; then
        spec_file="$repo_root/tasks/${spec_slug}.md"
        if [[ ! -f "$spec_file" ]]; then
          echo "  ⚠️  [Gate 2.1] Spec file not found: tasks/${spec_slug}.md (continuing)"
        elif grep -qi 'Status.*abandoned' "$spec_file" 2>/dev/null; then
          echo "  ⚠️  [Gate 2.1] Spec tasks/${spec_slug}.md is abandoned (continuing)"
        fi
      fi
    fi
  fi
  fi  # end WORKSPACE_MODE gate 2

  # Gate 3: Pre-commit trailer check (catch hook bypasses)
  # v2: verifies tree-hash anti-forgery (2026-03-12, gates-hardening-v2)
  # Skip for workspace repos UNLESS .githooks/ changed (gate integrity)
  if [[ $WORKSPACE_MODE -eq 0 ]] || [[ $hooks_changed -eq 1 ]]; then
  g3_failed=0
  while IFS= read -r sha; do
    msg=$(git log -1 --format='%B' "$sha")
    # Skip actual merge commits (2+ parents), not just "Merge*" message prefix
    parent_count=$(git rev-list --parents -n1 "$sha" 2>/dev/null | wc -w)
    parent_count=$((parent_count - 1))  # subtract the commit itself
    if [[ $parent_count -ge 2 ]]; then
      continue
    fi
    # Extract trailer value
    trailer_val=$(echo "$msg" | sed -n 's/^Pre-commit-gate: //p' | tail -1)
    if [[ -z "$trailer_val" ]]; then
      echo "  ❌ Commit ${sha:0:8} missing Pre-commit-gate trailer (hooks bypassed?)"
      _tel hook-tree-hash block
      g3_failed=1
      failed=1
    elif [[ "$trailer_val" == "passed" ]]; then
      # Legacy plain-text trailer — reject (potential forgery or pre-v2 commit)
      echo "  ❌ Commit ${sha:0:8} has legacy 'passed' trailer (v2 requires tree-hash)"
      echo "     Amend the commit to regenerate: git commit --amend --no-edit"
      _tel hook-tree-hash block
      g3_failed=1
      failed=1
    else
      # Verify tree-hash matches
      actual_tree=$(git rev-parse "${sha}^{tree}" 2>/dev/null || true)
      if [[ "$trailer_val" != "$actual_tree" ]]; then
        echo "  ❌ Commit ${sha:0:8} tree-hash mismatch (trailer: ${trailer_val:0:8}… actual: ${actual_tree:0:8}…)"
        echo "     Trailer was forged or commit was modified after hook. Amend to fix."
        _tel hook-tree-hash block
        g3_failed=1
        failed=1
      fi
    fi
  done < <(git rev-list "$range" 2>/dev/null || true)
  if [[ $g3_failed -eq 0 ]]; then
    _tel hook-tree-hash pass
  fi
  fi  # end WORKSPACE_MODE gate 3 skip

  # Gate 4: Cumulative TDD enforcement — push must include tests if it includes code
  # Checks the ENTIRE push range (not per-commit). Code in commit A + tests in commit B = OK.
  # Skips repos without a test framework (warn only).
  g4_has_code=0
  g4_has_tests=0
  g4_code_list=""

  # Detect test framework in repo
  g4_has_framework=0
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  if [[ -f "$repo_root/vitest.config.ts" || -f "$repo_root/vitest.config.mts" || -f "$repo_root/vitest.config.js" ]]; then
    g4_has_framework=1
  elif grep -q '"jest"' "$repo_root/package.json" 2>/dev/null; then
    g4_has_framework=1
  elif [[ -f "$repo_root/pytest.ini" ]] || grep -q "pytest" "$repo_root/pyproject.toml" 2>/dev/null; then
    g4_has_framework=1
  elif [[ -f "$repo_root/go.mod" ]]; then
    g4_has_framework=1
  elif [[ -f "$repo_root/Cargo.toml" ]]; then
    g4_has_framework=1
  elif command -v bats &>/dev/null && find "$repo_root" -maxdepth 2 -name "*.bats" -print -quit 2>/dev/null | grep -q .; then
    g4_has_framework=1
  fi

  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    # Skip docs, configs, styles, assets, lockfiles
    echo "$f" | grep -qE '\.(md|txt|rst|adoc|mdx|json|ya?ml|toml|ini|env|css|scss|sass|less|svg|png|jpg|gif|ico|woff2?|eot|ttf)$' && continue
    echo "$f" | grep -qE '(package-lock|yarn\.lock|pnpm-lock|Cargo\.lock|poetry\.lock|go\.sum)' && continue
    # Test file?
    if echo "$f" | grep -qE '(\.|_)(test|spec)\.[^/]+$|^(tests|__tests__|test|spec)/|^test_[^/]+\.[^/]+$|\.bats$'; then
      g4_has_tests=1
    else
      g4_has_code=1
      g4_code_list="$g4_code_list\n    $f"
    fi
  done <<< "$(git diff --name-only "$range" 2>/dev/null || true)"

  if [[ $g4_has_code -eq 1 && $g4_has_tests -eq 0 ]]; then
    if [[ $g4_has_framework -eq 1 ]]; then
      echo "  ❌ [Gate 4 TDD] Push has code changes but no test changes"
      echo -e "     Code files:$g4_code_list"
      echo "     Fix: add tests, or use: bash scripts/git-push-safe.sh"
      # Write file list for auto-remediation
      echo -e "$g4_code_list" | sed 's/^[[:space:]]*//' | grep -v '^$' > /tmp/.tdd-gate4-files 2>/dev/null || true
      _tel hook-tdd block
      failed=1
    else
      echo "  ⚠️  [Gate 4 TDD] Code changes without tests (no test framework detected — warning only)"
    fi
  fi

  if [[ $g4_has_code -eq 1 && $g4_has_tests -eq 1 ]]; then
    _tel hook-tdd pass
  fi

  # Gate 5: Lint/typecheck — auto-run if project has config (skip workspace repos)
  if [[ $WORKSPACE_MODE -eq 0 ]]; then
    g5_ran=0
    # TypeScript typecheck
    if [[ -f "$repo_root/tsconfig.json" ]] || [[ -f "$repo_root/tsconfig.app.json" ]]; then
      # Check if any TS/TSX/JS/JSX files changed in this push
      ts_changed=$(git diff --name-only "$range" 2>/dev/null | grep -cE '\.(ts|tsx|js|jsx)$' || true)
      if [[ "$ts_changed" -gt 0 ]]; then
        echo "  ⏳ [Gate 5] Running typecheck..."
        g5_ran=1
        g5_output=""
        # Use npx tsc --noEmit with 30s timeout (perl for macOS portability)
        if g5_output=$(cd "$repo_root" && perl -e 'alarm 30; exec @ARGV' -- npx tsc --noEmit 2>&1); then
          echo "  ✅ [Gate 5] Typecheck passed"
          _tel hook-typecheck pass
        else
          g5_exit=$?
          if [[ $g5_exit -eq 142 ]]; then
            echo "  ⚠️  [Gate 5] Typecheck timed out (>30s), skipping"
          else
            echo "  ❌ [Gate 5 Typecheck] Failed — fix these errors before pushing:"
            echo ""
            echo "$g5_output" | head -30
            if [[ $(echo "$g5_output" | wc -l) -gt 30 ]]; then
              echo "  ... ($(echo "$g5_output" | wc -l | tr -d ' ') total lines, showing first 30)"
            fi
            echo ""
            echo "  Run locally: cd $repo_root && npx tsc --noEmit"
            _tel hook-typecheck block
            failed=1
          fi
        fi
      fi
    fi
    # ESLint (only if no typecheck ran and eslint config exists)
    if [[ $g5_ran -eq 0 ]]; then
      if [[ -f "$repo_root/.eslintrc.js" ]] || [[ -f "$repo_root/.eslintrc.json" ]] || [[ -f "$repo_root/eslint.config.js" ]] || [[ -f "$repo_root/eslint.config.mjs" ]]; then
        js_changed=$(git diff --name-only "$range" 2>/dev/null | grep -cE '\.(ts|tsx|js|jsx)$' || true)
        if [[ "$js_changed" -gt 0 ]]; then
          echo "  ⏳ [Gate 5] Running eslint..."
          if g5_output=$(cd "$repo_root" && perl -e 'alarm 30; exec @ARGV' -- npx eslint --no-warn-ignored $(git diff --name-only --diff-filter=ACMR "$range" 2>/dev/null | grep -E '\.(ts|tsx|js|jsx)$' | tr '\n' ' ') 2>&1); then
            echo "  ✅ [Gate 5] ESLint passed"
            _tel hook-eslint pass
          else
            g5_exit=$?
            if [[ $g5_exit -eq 142 ]]; then
              echo "  ⚠️  [Gate 5] ESLint timed out (>30s), skipping"
            else
              echo "  ❌ [Gate 5 ESLint] Failed — fix these errors before pushing:"
              echo ""
              echo "$g5_output" | head -30
              echo ""
              echo "  Run locally: cd $repo_root && npx eslint <files>"
              _tel hook-eslint block
              failed=1
            fi
          fi
        fi
      fi
    fi
  fi

  # Gate 6: E2E awareness for page-level changes
  # Only triggers for Web App projects (has playwright.config.ts)
  # Only checks page.tsx/layout.tsx/pages/**/*.tsx/src/App.tsx changes
  if [[ "${SKIP_E2E_GATE:-0}" != "1" ]]; then
    g6_has_pw=0
    # Check for playwright config in repo root or monorepo apps/*/
    if [[ -f "$repo_root/playwright.config.ts" ]]; then
      g6_has_pw=1
    else
      for pw_cfg in "$repo_root"/apps/*/playwright.config.ts; do
        [[ -f "$pw_cfg" ]] && { g6_has_pw=1; break; }
      done
    fi

    if [[ $g6_has_pw -eq 1 ]]; then
      g6_has_page_changes=0
      g6_has_e2e=0

      while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        # Page-level file?
        if echo "$f" | grep -qE '(^|/)page\.(tsx|ts|jsx|js)$|(^|/)layout\.(tsx|ts|jsx|js)$|pages/[^_\[].+\.(tsx|jsx)$|src/App\.(tsx|jsx)$'; then
          g6_has_page_changes=1
        fi
        # E2E test file?
        if echo "$f" | grep -qE '(^|/)e2e/.*\.spec\.(ts|js)$'; then
          g6_has_e2e=1
        fi
      done <<< "$(git diff --name-only "$range" 2>/dev/null || true)"

      if [[ $g6_has_page_changes -eq 1 ]]; then
        # Check for [e2e-ack] in any commit message
        g6_has_ack=0
        if git log --format='%B' "$range" 2>/dev/null | grep -qF '[e2e-ack]'; then
          g6_has_ack=1
        fi

        if [[ $g6_has_e2e -eq 1 ]]; then
          echo "  ✅ [Gate 6 E2E] Page changes with e2e tests — good"
          _tel hook-e2e pass
        elif [[ $g6_has_ack -eq 1 ]]; then
          echo "  ✅ [Gate 6 E2E] Page changes with [e2e-ack] exemption"
          _tel hook-e2e pass
        elif [[ -f "$repo_root/vitest.config.ts" || -f "$repo_root/vitest.config.mts" || -f "$repo_root/vitest.config.js" ]]; then
          # Project has vitest configured — unit tests exist, warn only
          echo "  ⚠️  [Gate 6 E2E] Page-level changes without e2e tests (vitest project — warning only)"
          echo "     Consider adding e2e tests in e2e/*.spec.ts, or use [e2e-ack] to acknowledge"
          _tel hook-e2e pass
        else
          # No tests at all for page changes
          if [[ $WORKSPACE_MODE -eq 1 ]]; then
            echo "  ⚠️  [Gate 6 E2E] Page-level changes without e2e tests (workspace — warning only)"
          else
            echo "  ❌ [Gate 6 E2E] Page-level changes without e2e tests"
            echo "     Add e2e tests in e2e/*.spec.ts, or [e2e-ack] to exempt"
            _tel hook-e2e block
            failed=1
          fi
        fi
      fi
    fi
  fi

  # Gate 7: Spec delivery requires acceptance screenshots
  # When a spec is marked delivered (status change in tasks/*.md),
  # verify docs/acceptance/<slug>/ has screenshots OR e2e tests capture them
  g7_has_pw=0
  if [[ -f "$repo_root/playwright.config.ts" ]]; then
    g7_has_pw=1
  else
    for pw_cfg in "$repo_root"/apps/*/playwright.config.ts; do
      [[ -f "$pw_cfg" ]] && { g7_has_pw=1; break; }
    done
  fi
  if [[ "${SKIP_SCREENSHOT_GATE:-0}" != "1" ]] && [[ $g7_has_pw -eq 1 ]]; then
    # Check if any commit in this push marks a spec as delivered
    delivered_slugs=()
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      if echo "$f" | grep -qE '^tasks/.*\.md$'; then
        slug=$(basename "$f" .md)
        # Check if the file content has "delivered" status (scan first 20 lines for flexibility)
        if git show "$local_sha:$f" 2>/dev/null | head -20 | grep -qi 'delivered'; then
          delivered_slugs+=("$slug")
        fi
      fi
    done <<< "$(git diff --name-only "$range" 2>/dev/null || true)"

    for slug in "${delivered_slugs[@]+"${delivered_slugs[@]}"}"; do
      acc_dir="docs/acceptance/$slug"
      screenshot_count=0
      if [[ -d "$repo_root/$acc_dir" ]]; then
        screenshot_count=$(find "$repo_root/$acc_dir" -name "*.png" 2>/dev/null | wc -l | tr -d ' ')
      fi

      if [[ $screenshot_count -eq 0 ]]; then
        echo "  ⚠️  [Gate 7] Spec '$slug' marked delivered but docs/acceptance/$slug/ has no screenshots"
        echo "     Run: PW_SCREENSHOTS=on npx playwright test"
        echo "     Then commit screenshots to docs/acceptance/$slug/"
        _tel hook-screenshot warn
      else
        # Gate 7b: Dedup check — catch identical screenshots used to fake coverage
        unique_count=$screenshot_count
        if command -v md5sum >/dev/null 2>&1; then
          unique_count=$(find "$repo_root/$acc_dir" -name "*.png" -exec md5sum {} \; | awk '{print $1}' | sort -u | wc -l | tr -d ' ')
        elif command -v shasum >/dev/null 2>&1; then
          unique_count=$(find "$repo_root/$acc_dir" -name "*.png" -exec shasum {} \; | awk '{print $1}' | sort -u | wc -l | tr -d ' ')
        elif command -v md5 >/dev/null 2>&1; then
          unique_count=$(find "$repo_root/$acc_dir" -name "*.png" -exec md5 -q {} \; | sort -u | wc -l | tr -d ' ')
        fi
        dup_count=$((screenshot_count - unique_count))

        if [[ $dup_count -gt 0 ]]; then
          echo "  ⚠️  [Gate 7] Spec '$slug': $screenshot_count screenshots but $dup_count are duplicates ($unique_count unique)"
          echo "     截图不能用一样的图糊弄——每个截图必须对应不同的验证场景"
          _tel hook-screenshot-dedup warn
          failed=1
        else
          # Gate 7c: Visual similarity — catch same page screenshotted at different times
          visual_dup=0
          if command -v compare >/dev/null 2>&1 && [[ $screenshot_count -ge 2 ]] && [[ $screenshot_count -le 20 ]]; then
            pngs=()
            while IFS= read -r f; do
              [[ -n "$f" ]] && pngs+=("$f")
            done < <(find "$repo_root/$acc_dir" -name "*.png" | sort)
            for ((i=0; i<${#pngs[@]}; i++)); do
              for ((j=i+1; j<${#pngs[@]}; j++)); do
                # compare requires same dimensions — skip if different
                dims_i=$(identify -format "%wx%h" "${pngs[$i]}" 2>/dev/null || echo "0x0")
                dims_j=$(identify -format "%wx%h" "${pngs[$j]}" 2>/dev/null || echo "0x0")
                [[ "$dims_i" != "$dims_j" ]] && continue
                # RMSE normalized to 0-1: < 0.02 means visually identical
                cmp_out=$(compare -metric RMSE "${pngs[$i]}" "${pngs[$j]}" /dev/null 2>&1) || true
                rmse=$(echo "$cmp_out" | tr -d '\n' | sed -n 's/.*(\([0-9.]*\)).*/\1/p')
                # Skip if compare failed (invalid images) or no parseable output
                [[ -z "$rmse" ]] && continue
                # Compare as integers: rmse * 10000 < 200 means < 0.02
                rmse_int=$(printf '%.0f' "$(echo "$rmse * 10000" | bc 2>/dev/null || echo "10000")" 2>/dev/null)
                [[ -z "$rmse_int" ]] && continue
                if [[ $rmse_int -lt 200 ]]; then
                  echo "  ⚠️  [Gate 7] 视觉重复: $(basename "${pngs[$i]}") ≈ $(basename "${pngs[$j]}") (RMSE=$rmse)"
                  visual_dup=1
                fi
              done
            done
          fi
          if [[ $visual_dup -eq 1 ]]; then
            echo "     同一页面不同时间截的图也算重复——每张截图必须对应不同的验证场景"
            _tel hook-screenshot-visual-dedup warn
            failed=1
          else
            echo "  ✅ [Gate 7] Spec '$slug': $screenshot_count acceptance screenshots ($unique_count unique)"
            _tel hook-screenshot pass
          fi
        fi
      fi
    done
  fi

done

# ─── Project-specific sync (warn only, never block push) ───
if [[ -x "$repo_root/scripts/sync-docs.sh" ]]; then
  echo "  📄 [Docs sync] Running project docs sync..."
  if bash "$repo_root/scripts/sync-docs.sh" 2>/dev/null; then
    if ! git diff --quiet -- docs/ 2>/dev/null; then
      echo "  ⚠️  docs/ changed by sync — remember to commit synced docs"
    fi
  fi
  for acc in "$repo_root"/tasks/*-acceptance.md; do
    [[ -f "$acc" ]] || continue
    if grep -q '<!-- TODO' "$acc" 2>/dev/null; then
      echo "  ⚠️  [Docs] $(basename "$acc") contains unfilled TODOs"
    fi
  done
fi

# ─── Gate 8: Production verification (auto-trigger on deployment files) ───
VERIFY_PROD="${WORKSPACE_ROOT}/scripts/verify-production.sh"
if [[ -x "$VERIFY_PROD" ]]; then
  deploy_detected=0
  for f in "${changed_files[@]+"${changed_files[@]}"}"; do
    case "$f" in
      next.config.*|wrangler.toml|Dockerfile|.github/workflows/*.yml) deploy_detected=1; break ;;
    esac
  done
  if [[ $deploy_detected -eq 1 ]]; then
    echo ""
    echo "  🔍 [Gate 8] Deployment files detected — running production verification (15s timeout)..."
    if perl -e 'alarm 15; exec @ARGV' -- bash "$VERIFY_PROD" "$repo_root" 2>&1; then
      echo "  ✅ [Gate 8] Production verification passed"
    else
      exit_code=$?
      if [[ $exit_code -eq 142 ]]; then
        echo "  ⚠️  [Gate 8] Production verification timed out (>15s) — proceeding"
      elif [[ $WORKSPACE_MODE -eq 1 ]]; then
        echo "  ⚠️  [Gate 8] Production verification failed (workspace mode: warn only)"
      else
        echo "  ❌ [Gate 8] Production verification failed"
        failed=1
      fi
    fi
  fi
fi

if [[ $failed -eq 1 ]]; then
  echo ""
  echo "⛔ PRE-PUSH GATE FAILED — fix issues above before pushing"
  exit 1
fi

echo "✅ Pre-push gate: passed"
_tel hook-pre-push pass
exit 0
