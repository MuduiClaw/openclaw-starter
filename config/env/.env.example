# API Keys 清单
# 复制为 ~/.config/openclaw/.env 并填入你的值

# === LLM Provider（至少填一个）===
# ANTHROPIC_API_KEY=sk-ant-...           # Anthropic API（按量付费）
# 或使用 setup-token: openclaw models auth setup-token --provider anthropic

# OPENAI_API_KEY=sk-...                  # OpenAI（可选）
# GOOGLE_API_KEY=AI...                   # Google Gemini（可选）

# === Chat Channel（至少填一个）===
# DISCORD_BOT_TOKEN=...                  # Discord Bot
# 飞书在 openclaw.json channels.feishu 中配置

# === 可选 ===
# GITHUB_TOKEN=ghp_...                   # GitHub（PR/Issues 操作）
# CLOUDFLARE_ACCOUNT_ID=...              # Cloudflare（R2 存储等）
# CLOUDFLARE_API_TOKEN=...
